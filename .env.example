# MeetMe authentication configuration
# Copy to .env for local Netlify dev, and set the same values in Netlify Site settings.

JWT_SECRET=replace-with-a-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-a-different-long-random-secret
APP_URL=https://your-site.netlify.app

# Passwordless email link (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
AUTH_FROM_EMAIL=MeetMe <noreply@yourdomain.com>

# Resend webhook secret (bounce/complaint notifications)
# Generate a random string, e.g.: openssl rand -hex 32
# In Resend dashboard → Webhooks, set URL to:
#   https://your-site.netlify.app/api/webhooks/resend?secret=<this value>
# Subscribe to: email.bounced, email.complained
RESEND_WEBHOOK_SECRET=replace-with-a-random-secret

# Google OAuth (also used for Google Calendar integration)
GOOGLE_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Admin accounts (comma-separated emails)
# These users can access /admin.html — user edit, view all meetings, and event logs.
ADMIN_EMAILS=yusuf.pisan@gmail.com
