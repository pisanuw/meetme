{
  "name": "meetme",
  "private": true,
  "scripts": {
    "dev": "netlify dev --internal-disable-edge-functions --no-open -p 8888",
    "dev:offline": "netlify dev --internal-disable-edge-functions --offline --no-open -p 8888",
    "dev:oauth": "APP_URL=http://localhost:8888 netlify dev --internal-disable-edge-functions --no-open -p 8888",
    "dev:stop": "pkill -f \"[n]etlify dev\" || true",
    "test": "node --test",
    "lint": "eslint .",
    "predeploy-check": "npm test && npm run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@netlify/blobs": "^8.1.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "netlify-cli": "^24.6.2",
    "prettier": "^3.5.3"
  }
}
